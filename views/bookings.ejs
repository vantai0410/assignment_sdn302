<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quản lý đặt xe - Car Rental</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css"
    />
    <style>
      body {
        min-height: 100vh;
        background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
      }
      .navbar {
        background: rgba(255, 255, 255, 0.95) !important;
        backdrop-filter: blur(10px);
        box-shadow: 0 2px 20px rgba(0, 0, 0, 0.1);
      }
      .page-header {
        background: white;
        padding: 2rem;
        border-radius: 15px;
        margin: 2rem 0;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
      }
      .table-container {
        background: white;
        padding: 1.5rem;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
      }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
      <div class="container">
        <a class="navbar-brand fw-bold" href="/">
          <i class="bi bi-car-front-fill me-2"></i>Car Rental
        </a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item">
              <a class="nav-link" href="/"
                ><i class="bi bi-house-fill"></i> Trang chủ</a
              >
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/cars"
                ><i class="bi bi-car-front"></i> Xe</a
              >
            </li>
            <li class="nav-item">
              <a class="nav-link active" href="/bookings"
                ><i class="bi bi-calendar-check"></i> Đặt xe</a
              >
            </li>
            <li class="nav-item">
              <span class="nav-link" id="userDisplay"></span>
            </li>
            <li class="nav-item">
              <button class="btn btn-sm btn-danger ms-2" onclick="logout()">
                <i class="bi bi-box-arrow-right"></i> Logout
              </button>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <div class="container">
      <div class="page-header">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h1>
              <i class="bi bi-calendar-check-fill me-2"></i>Quản lý đặt xe
            </h1>
            <p class="text-muted mb-0">Quản lý đơn đặt xe cho thuê</p>
          </div>
          <button
            class="btn btn-primary btn-lg"
            data-bs-toggle="modal"
            data-bs-target="#bookingModal"
            onclick="openAddForm()"
          >
            <i class="bi bi-plus-circle me-2"></i>Đặt xe mới
          </button>
        </div>
      </div>

      <div class="table-container">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Khách hàng</th>
              <th>Biển số xe</th>
              <th>Ngày bắt đầu</th>
              <th>Ngày kết thúc</th>
              <th>Tổng tiền</th>
              <th>Ngày thực trả</th>
              <th>Tiền phạt</th>
              <th>Thao tác</th>
            </tr>
          </thead>
          <tbody id="bookingsTable">
            <tr>
              <td colspan="6" class="text-center">Đang tải...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Modal Form -->
    <div class="modal fade" id="bookingModal" tabindex="-1">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="modalTitle">Đặt xe mới</h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
            ></button>
          </div>
          <div class="modal-body">
            <form id="bookingForm">
              <input type="hidden" id="bookingId" />
              <div class="mb-3">
                <label class="form-label">Tên khách hàng *</label>
                <div
                  class="form-control bg-light"
                  id="customerNameDisplay"
                  style="border: 1px solid #dee2e6"
                >
                  <span id="customerNameText">--</span>
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label">Chọn xe *</label>
                <select
                  class="form-select"
                  id="carNumber"
                  required
                  onchange="updatePrice()"
                >
                  <option value="">-- Chọn xe --</option>
                </select>
              </div>
              <div class="row">
                <div class="col-md-6 mb-3">
                  <label class="form-label">Ngày bắt đầu *</label>
                  <input
                    type="date"
                    class="form-control"
                    id="startDate"
                    required
                    onchange="updatePrice()"
                  />
                </div>
                <div class="col-md-6 mb-3">
                  <label class="form-label">Ngày kết thúc *</label>
                  <input
                    type="date"
                    class="form-control"
                    id="endDate"
                    required
                    onchange="updatePrice()"
                  />
                </div>
              </div>
              <div
                class="alert alert-info"
                id="priceInfo"
                style="display: none"
              >
                <strong>Ước tính:</strong><br />
                Số ngày: <span id="numDays">0</span><br />
                Tổng tiền: <strong><span id="totalPrice">0</span> đ</strong>
              </div>
            </form>
          </div>
          <div class="modal-footer">
            <button
              type="button"
              class="btn btn-secondary"
              data-bs-dismiss="modal"
            >
              Hủy
            </button>
            <button
              type="button"
              class="btn btn-primary"
              onclick="saveBooking()"
            >
              Lưu
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Return Modal -->
    <div class="modal fade" id="returnModal" tabindex="-1">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Trả xe</h5>
            <button
              type="button"
              class="btn-close"
              data-bs-dismiss="modal"
            ></button>
          </div>
          <div class="modal-body">
            <form id="returnForm">
              <input type="hidden" id="returnBookingId" />
              <div class="mb-3">
                <label class="form-label">Ngày giờ trả thực tế *</label>
                <input
                  type="datetime-local"
                  class="form-control"
                  id="actualReturnDate"
                  required
                />
              </div>
            </form>
          </div>
          <div class="modal-footer">
            <button
              type="button"
              class="btn btn-secondary"
              data-bs-dismiss="modal"
            >
              Hủy
            </button>
            <button
              type="button"
              class="btn btn-success"
              onclick="saveReturnCar()"
            >
              Xác nhận trả
            </button>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      // Check login
      document.addEventListener("DOMContentLoaded", () => {
        const token = localStorage.getItem("auth_token");
        if (!token) {
          window.location.href = "/login";
          return;
        }

        // Display user info
        const user = JSON.parse(localStorage.getItem("user") || "{}");
        if (user.username) {
          document.getElementById("userDisplay").innerHTML =
            `<i class="bi bi-person-circle"></i> ${user.username}`;
        }
      });

      // Logout function
      function logout() {
        if (confirm("Bạn chắc chắn muốn logout?")) {
          localStorage.removeItem("auth_token");
          localStorage.removeItem("user");
          window.location.href = "/login";
        }
      }

      // Helper to get auth headers
      function getAuthHeaders() {
        const token = localStorage.getItem("auth_token");
        return {
          Authorization: "Bearer " + token,
          "Content-Type": "application/json",
        };
      }

      let bookings = [];
      let cars = [];
      let editingId = null;
      const modal = new bootstrap.Modal(
        document.getElementById("bookingModal"),
      );
      const returnModal = new bootstrap.Modal(
        document.getElementById("returnModal"),
      );

      // Mở form trả xe
      function openReturnForm(id) {
        document.getElementById("returnBookingId").value = id;

        // Tạo chuỗi datetime-local (YYYY-MM-DDThh:mm)
        const now = new Date();
        now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
        document.getElementById("actualReturnDate").value = now
          .toISOString()
          .slice(0, 16);

        returnModal.show();
      }

      // Lưu trả xe
      async function saveReturnCar() {
        const id = document.getElementById("returnBookingId").value;
        const actualReturnDate =
          document.getElementById("actualReturnDate").value;

        if (!actualReturnDate) {
          alert("Vui lòng nhập ngày giờ trả");
          return;
        }

        try {
          const res = await fetch(`/api/bookings/${id}`, {
            method: "PUT",
            headers: getAuthHeaders(),
            body: JSON.stringify({
              actualReturnDate: new Date(actualReturnDate).toISOString(),
            }),
          });

          const result = await res.json();
          if (result.success) {
            returnModal.hide();
            loadData();
          } else {
            alert("Lỗi: " + result.message);
          }
        } catch (error) {
          alert("Lỗi: " + error.message);
        }
      }

      // Load bookings và cars
      async function loadData() {
        try {
          const [bookingsRes, carsRes] = await Promise.all([
            fetch("/api/bookings", {
              headers: {
                Authorization: "Bearer " + localStorage.getItem("auth_token"),
              },
            }),
            fetch("/api/cars"),
          ]);
          bookings = await bookingsRes.json();
          cars = await carsRes.json();
          renderBookings();
        } catch (error) {
          alert("Lỗi khi tải dữ liệu: " + error.message);
        }
      }

      // Render bảng bookings
      function renderBookings() {
        const tbody = document.getElementById("bookingsTable");
        if (bookings.length === 0) {
          tbody.innerHTML =
            '<tr><td colspan="6" class="text-center">Chưa có đơn đặt xe nào</td></tr>';
          return;
        }

        tbody.innerHTML = bookings
          .map(
            (b) => `
        <tr>
          <td><i class="bi bi-person-fill me-2 text-primary"></i>${b.customerName}</td>
          <td><i class="bi bi-car-front me-2 text-success"></i>${b.carNumber}</td>
          <td>${new Date(b.startDate).toLocaleDateString("vi-VN")}</td>
          <td>${new Date(b.endDate).toLocaleDateString("vi-VN")}</td>
          <td class="text-success fw-bold">${(b.totalAmount || 0).toLocaleString()} đ</td>
          <td>${b.actualReturnDate ? new Date(b.actualReturnDate).toLocaleDateString("vi-VN") + " " + new Date(b.actualReturnDate).toLocaleTimeString("vi-VN", { hour: "2-digit", minute: "2-digit" }) : '<span class="text-warning">Chưa trả</span>'}</td>
          <td class="text-danger fw-bold">${(b.penaltyAmount || 0).toLocaleString()} đ</td>
          <td>
            ${!b.actualReturnDate ? `<button class="btn btn-sm btn-outline-success me-1" onclick="openReturnForm('${b._id}')" title="Trả xe"><i class="bi bi-box-arrow-in-right"></i></button>` : ""}
            <button class="btn btn-sm btn-outline-primary me-1" onclick="openEditForm('${b._id}')">
              <i class="bi bi-pencil"></i>
            </button>
            <button class="btn btn-sm btn-outline-danger" onclick="deleteBooking('${b._id}')">
              <i class="bi bi-trash"></i>
            </button>
          </td>
        </tr>
      `,
          )
          .join("");
      }

      // Mở form thêm
      function openAddForm() {
        editingId = null;
        document.getElementById("modalTitle").textContent = "Đặt xe mới";
        document.getElementById("bookingForm").reset();

        // Display current user's username
        const user = JSON.parse(localStorage.getItem("user") || "{}");
        document.getElementById("customerNameText").textContent =
          user.username || "--";

        loadCarsToSelect();
        const today = new Date().toISOString().split("T")[0];
        document.getElementById("startDate").min = today;
        document.getElementById("endDate").min = today;
        document.getElementById("priceInfo").style.display = "none";
      }

      // Mở form sửa
      function openEditForm(id) {
        editingId = id;
        const booking = bookings.find((b) => b._id === id);
        document.getElementById("modalTitle").textContent = "Sửa đặt xe";
        // Display booking's customer name (read-only)
        document.getElementById("customerNameText").textContent =
          booking.customerName;
        document.getElementById("startDate").value =
          booking.startDate.split("T")[0];
        document.getElementById("endDate").value =
          booking.endDate.split("T")[0];
        loadCarsToSelect();
        setTimeout(() => {
          document.getElementById("carNumber").value = booking.carNumber;
          updatePrice();
        }, 100);
        modal.show();
      }

      // Load cars vào select
      function loadCarsToSelect() {
        const select = document.getElementById("carNumber");
        select.innerHTML =
          '<option value="">-- Chọn xe --</option>' +
          cars
            .map(
              (car) => `
          <option value="${car.carNumber}" data-price="${car.pricePerDay || 0}" ${car.status !== "available" ? "disabled" : ""}>
            ${car.carNumber} - ${car.capacity || 0} chỗ - ${(car.pricePerDay || 0).toLocaleString()} đ/ngày
            ${car.status !== "available" ? "(" + car.status + ")" : ""}
          </option>
        `,
            )
            .join("");
      }

      // Tính giá
      function updatePrice() {
        const carSelect = document.getElementById("carNumber");
        const startDate = new Date(document.getElementById("startDate").value);
        const endDate = new Date(document.getElementById("endDate").value);
        const selected = carSelect.options[carSelect.selectedIndex];

        if (
          selected &&
          selected.value &&
          startDate &&
          endDate &&
          endDate > startDate
        ) {
          const diffTime = Math.abs(endDate - startDate);
          const days = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) || 1;
          const price = parseFloat(selected.dataset.price) || 0;
          const total = days * price;

          document.getElementById("numDays").textContent = days;
          document.getElementById("totalPrice").textContent = (
            total || 0
          ).toLocaleString();
          document.getElementById("priceInfo").style.display = "block";
        } else {
          document.getElementById("priceInfo").style.display = "none";
        }
      }

      // Lưu booking
      async function saveBooking() {
        const carNumber = document.getElementById("carNumber").value;
        const startDate = document.getElementById("startDate").value;
        const endDate = document.getElementById("endDate").value;

        // Backend will auto-fill customerName from authenticated user
        const data = { carNumber, startDate, endDate };

        try {
          let res;
          if (editingId) {
            res = await fetch(`/api/bookings/${editingId}`, {
              method: "PUT",
              headers: getAuthHeaders(),
              body: JSON.stringify(data),
            });
          } else {
            res = await fetch("/api/bookings", {
              method: "POST",
              headers: getAuthHeaders(),
              body: JSON.stringify(data),
            });
          }

          const result = await res.json();
          if (result.success) {
            modal.hide();
            loadData();
          } else {
            alert("Lỗi: " + result.message);
          }
        } catch (error) {
          alert("Lỗi: " + error.message);
        }
      }

      // Xóa booking
      async function deleteBooking(id) {
        if (!confirm("Bạn chắc chắn muốn xóa đơn này?")) return;

        try {
          const res = await fetch(`/api/bookings/${id}`, {
            method: "DELETE",
            headers: getAuthHeaders(),
          });
          const result = await res.json();
          if (result.success) {
            loadData();
          } else {
            alert("Lỗi: " + result.message);
          }
        } catch (error) {
          alert("Lỗi: " + error.message);
        }
      }

      loadData();
    </script>
  </body>
</html>
