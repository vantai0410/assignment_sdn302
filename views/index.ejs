<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Car Rental System</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css"
    />
    <style>
      body {
        min-height: 100vh;
        background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
      }
      .navbar {
        background: rgba(255, 255, 255, 0.95) !important;
        backdrop-filter: blur(10px);
        box-shadow: 0 2px 20px rgba(0, 0, 0, 0.1);
      }
      .hero {
        color: white;
        text-align: center;
        padding: 4rem 0;
      }
      .stat-card {
        background: white;
        padding: 2rem;
        border-radius: 15px;
        text-align: center;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        transition: transform 0.3s;
      }
      .stat-card:hover {
        transform: translateY(-10px);
      }
      .stat-card i {
        font-size: 3rem;
        color: #e74c3c;
      }
      .stat-card h2 {
        font-size: 2.5rem;
        font-weight: 700;
        color: #e74c3c;
        margin: 1rem 0;
      }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
      <div class="container">
        <a class="navbar-brand fw-bold" href="/">
          <i class="bi bi-car-front-fill me-2"></i>Car Rental
        </a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav ms-auto">
            <li class="nav-item">
              <a class="nav-link active" href="/"
                ><i class="bi bi-house-fill"></i> Trang chủ</a
              >
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/cars"
                ><i class="bi bi-car-front"></i> Xe</a
              >
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/bookings"
                ><i class="bi bi-calendar-check"></i> Đặt xe</a
              >
            </li>
            <li class="nav-item">
              <span class="nav-link" id="userDisplay"></span>
            </li>
            <li class="nav-item">
              <button class="btn btn-sm btn-danger ms-2" onclick="logout()">
                <i class="bi bi-box-arrow-right"></i> Logout
              </button>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <div class="hero">
      <div class="container">
        <h1><i class="bi bi-car-front-fill"></i> Car Rental System</h1>
        <p class="lead">Hệ thống quản lý cho thuê xe</p>
        <div class="mt-4">
          <a href="/bookings" class="btn btn-primary btn-lg me-3">
            <i class="bi bi-plus-circle me-2"></i>Đặt xe ngay
          </a>
          <a href="/cars" class="btn btn-light btn-lg">
            <i class="bi bi-car-front me-2"></i>Xem xe
          </a>
        </div>
      </div>
    </div>

    <div class="container my-5">
      <div class="row g-4">
        <div class="col-md-4">
          <div class="stat-card">
            <i class="bi bi-car-front-fill"></i>
            <h2 id="totalCars">0</h2>
            <p class="text-muted">Tổng số xe</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="stat-card">
            <i class="bi bi-calendar-check-fill"></i>
            <h2 id="totalBookings">0</h2>
            <p class="text-muted">Tổng đơn đặt</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="stat-card">
            <i class="bi bi-check-circle-fill text-success"></i>
            <h2 id="availableCars">0</h2>
            <p class="text-muted">Xe khả dụng</p>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      // Check nếu user chưa login thì redirect về login
      document.addEventListener("DOMContentLoaded", () => {
        const token = localStorage.getItem("auth_token");
        if (!token) {
          window.location.href = "/login";
          return;
        }

        // Display user info + set navbar based on role
        const user = JSON.parse(localStorage.getItem("user") || "{}");
        if (user.username) {
          document.getElementById("userDisplay").innerHTML =
            `<i class="bi bi-person-circle"></i> ${user.username}`;
        }

        // Ẩn link quản lý xe nếu customer
        if (user.role === "customer") {
          // Hide admin links
          const adminLinks = document.querySelectorAll(
            "a[href='/cars'], a[href='/bookings']",
          );
          adminLinks.forEach((link) => {
            if (link.href.includes("/cars")) {
              link.closest(".nav-item").style.display = "none";
            }
          });
        }
      });

      // Logout function
      function logout() {
        if (confirm("Bạn chắc chắn muốn logout?")) {
          localStorage.removeItem("auth_token");
          localStorage.removeItem("user");
          window.location.href = "/login";
        }
      }

      // Gọi API để lấy thống kê
      async function loadStats() {
        try {
          const [carsRes, bookingsRes] = await Promise.all([
            fetch("/api/cars"),
            fetch("/api/bookings"),
          ]);

          const cars = await carsRes.json();
          const bookings = await bookingsRes.json();

          document.getElementById("totalCars").textContent = cars.length;
          document.getElementById("totalBookings").textContent =
            bookings.length;
          document.getElementById("availableCars").textContent = cars.filter(
            (car) => car.status === "available",
          ).length;
        } catch (error) {
          console.error("Lỗi:", error);
        }
      }

      loadStats();
    </script>
  </body>
</html>
